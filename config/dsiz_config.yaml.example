# DSIZ Configuration (MVP)
# Скопируйте в dsiz_config.yaml и настройте под ваше производство

# Workforce Requirements (Нормы укомплектованности)
workforce:
  # Реактор: 1 оператор (обязательно)
  WC_REACTOR_MAIN:
    OPERATOR:
      required_count: 1
      is_mandatory: true
  
  # Тубировка: оператор + упаковщик (оба обязательны)
  WC_TUBE_LINE_1:
    OPERATOR:
      required_count: 1
      is_mandatory: true
    PACKER:
      required_count: 1
      is_mandatory: true
  
  # Линии розлива 1 и 2: по 4 оператора (3=0.5 rate)
  WC_FILL_LINE_1:
    OPERATOR:
      required_count: 4
      is_mandatory: false
      min_count_for_degraded_mode: 3
      degradation_factor: 0.5
  WC_FILL_LINE_2:
    OPERATOR:
      required_count: 4
      is_mandatory: false
      min_count_for_degraded_mode: 3
      degradation_factor: 0.5

# Reactor Configuration
reactor:
  max_cycles_per_shift: 2
  cip_schedule: "monday_shift_1"

# Work Center Modes (Режимы реактора)
work_center_modes:
  WC_REACTOR_MAIN:
    CREAM_MODE:
      min_load_kg: 700.0
      max_load_kg: 1400.0
      cycle_duration_hours: 4
      max_cycles_per_shift: 2
    PASTE_MODE:
      min_load_kg: 750.0
      max_load_kg: 1500.0
      cycle_duration_hours: 5
      max_cycles_per_shift: 2

# Product Work Center Routing (Маршрутизация продуктов)
product_routing:
  # Примеры маршрутизации ГП → рабочие центры
  # "FG_PASTE_200ML":
  #   WC_TUBE_LINE_1:
  #     is_allowed: true
  #     min_quantity_for_wc: null
  #     priority_order: 1

# Base Rates (будут использоваться в Phase 2)
base_rates:
  # Примеры скоростей по продуктам и центрам
  # product_sku: WC_ID: rate_units_per_hour
  # "Спрей100мл": "WC_FILL_LINE_1": 5000
